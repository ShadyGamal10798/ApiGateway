{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "LevelSwitches": {
      "$seqSwitch": "Information"
    },
    "MinimumLevel": {
      "ControlledBy": "$seqSwitch",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "ApiGateway",
      "System": "ApiGateway"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://10.180.20.22:5341",
          "apiKey": "",
          "controlLevelSwitch": "$seqSwitch"
        }
      }
    ]
  },
  "GatewayLogging": {
    "LogRequestBody": true,
    "LogResponseBody": true,
    "MaxLoggedBodyBytes": 65536
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "ReverseProxy": {
    "Routes": {
      "madar-operation-stage-route": {
        "ClusterId": "madar-operation-stage-cluster",
        "Match": {
          "Path": "/madar-operation/{**catch-all}"
        },
        "Metadata": {
          "System": "madar-operation"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/madar-operation"
          }
        ]
      },
      "madar-business-stage-route": {
        "ClusterId": "madar-business-stage-cluster",
        "Match": {
          "Path": "/madar-business/{**catch-all}"
        },
        "Metadata": {
          "System": "madar-business"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/madar-business"
          }
        ]
      },
      "auth-shared-route": {
        "ClusterId": "auth-shared-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Metadata": {
          "System": "SSO"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      }
    },
    "Clusters": {
      "madar-operation-stage-cluster": {
        "Destinations": {
          "madar-operation-stage-destination": {
            "Address": "https://lmsv2.nfsc.sa:8081/"
          }
        }
      },
      "madar-business-stage-cluster": {
        "Destinations": {
          "madar-business-stage-destination": {
            "Address": "https://simah-uat.nfsc.sa:8093/"
          }
        }
      },
      "auth-shared-cluster": {
        "Destinations": {
          "auth-shared-destination": {
            "Address": "https://auth-stage.nfsc.sa/"
          }
        }
      }
    }
  }
}
